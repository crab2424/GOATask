# deploy/.env にコピーして値を埋める。DB_PASSWORD は docker-compose.yml からも参照される。

DB_PASSWORD=CHANGE_ME

PORT=8080
DATABASE_URL=postgres://goatask:CHANGE_ME@127.0.0.1:5432/goatask?sslmode=disable
STATIC_DIR=/opt/goatask/frontend/dist
COOKIE_SECURE=true
SIGNUP_INVITE_CODE=CHANGE_ME
BACKUP_TOKEN=CHANGE_ME

# OCI Object Storage（非公開バケット）
OCI_REGION=ap-tokyo-1
OCI_OBJECT_STORAGE_NAMESPACE=nrskptzjyhtw
OCI_BUCKET_NAME=goatask-files
FILE_MAX_BYTES=52428800
FILE_MAX_USER_BYTES=524288000
